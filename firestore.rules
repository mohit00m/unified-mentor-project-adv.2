rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Rule for the 'users' collection
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow admin registration with secret key
      allow create: if request.auth != null 
                    && request.resource.data.role == "admin"
                    && request.resource.data.secretKey == "HERITAGE2026";
    }

    // Rule for Bookings
    match /bookings/{bookingId} {
      // Allow users to create bookings and READ their own bookings
      allow create: if request.auth != null;
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      
      // Only admins can update (Approve/Reject) or delete
      allow update, delete: if isAdmin();
    }
    
    // Rule for Inventory
    match /agency/inventory {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Rule for Complaints
    match /complaints/{complaintId} {
      // Allow users to create complaints and READ their own
      allow create: if request.auth != null;
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      
      // Only admins can resolve or delete
      allow update, delete: if isAdmin();
    }
  }
}